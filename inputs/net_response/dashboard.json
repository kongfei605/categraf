                                },
                                {
                                    "type": "special",
                                    "match": {
                                        "special": 1
                                    },
                                    "result": {
                                        "text": "TIMEOUT",
                                        "color": "#ce4f52"
                                    }
                                },
                                {
                                    "type": "special",
                                    "match": {
                                        "special": 2
                                    },
                                    "result": {
                                        "text": "CONN_FAILED",
                                        "color": "#ce4f52"
                                    }
                                },
                                {
                                    "type": "special",
                                    "match": {
                                        "special": 3
                                    },
                                    "result": {
                                        "text": "READ_FAILED",
                                        "color": "#f5a623"
                                    }
                                },
                                {
                                    "type": "special",
                                    "match": {
                                        "special": 4
                                    },
                                    "result": {
                                        "text": "STRING_MISMATCH",
                                        "color": "#f5a623"
                                    }
                                }
                            ],
                            "standardOptions": {}
                        }
                    },
                    {
                        "matcher": {
                            "value": "B"
                        },
                        "properties": {
                            "standardOptions": {
                                "unit": "s"
                            }
                        }
                    }
                ],
                "layout": {
                    "h": 5,
                    "w": 24,
                    "x": 0,
                    "y": 9,
                    "i": "net-response-global-table",
                    "isResizable": true
                },
                "id": "net-response-global-table"
            },
            {
